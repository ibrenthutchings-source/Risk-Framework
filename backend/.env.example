# Postgres connection (Railway injects this from the Postgres plugin)
DATABASE_URL=postgres://user:password@localhost:5432/chainproof

# Redis connection (Railway injects this from the Redis plugin)
REDIS_URL=redis://localhost:6379

# JWT signing secret — never commit a real value
JWT_SECRET=change-me-in-every-environment

# Dune Analytics — server-side only, never returned in a response body
DUNE_API_KEY=

# RPC provider (Alchemy/Infura/etc.) — server-side only
RPC_PROVIDER_URL=
RPC_API_KEY=

# Object storage for workpaper exports (S3-compatible: AWS S3 or Cloudflare R2)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=

PORT=8080
NODE_ENV=development
