{
  "name": "chainproof-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations -j js",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations -j js",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "test": "node --require tsx/cjs --test test/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.622.0",
    "bullmq": "^5.12.12",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
