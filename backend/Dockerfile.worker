# Shared build stage — api and worker differ only in the final CMD.
FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY package.json ./
RUN npm install --omit=dev
COPY --from=builder /app/dist ./dist

# No EXPOSE — worker has no public port, it only connects out to Postgres/Redis.
CMD ["node", "dist/worker/index.js"]
